# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="MY_APP_URL"

# EMAIL SETUP (Nodemailer)
# Your Gmail address that sends emails
EMAIL_USER="your@gmail.com"
# Gmail App Password (NOT your normal password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASS="your_app_password_here"
# Where quote requests get delivered (your business email)
EMAIL_TO="sales@stichpunch.com"
